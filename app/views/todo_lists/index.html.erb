<h1>New To-Do list</h1>
<%=render "form", todo_list = @todo_list %>

<%= link_to "New Todo List", new_todo_list_path%>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Description</th>
      <th colspan="3">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @todo_list.each do |tl|%>
      <tr>
        <td><%= tl.name %></td>
        <td><%= tl.description %></td>
        <td>
          <%= link_to "Show", todo_list_path(tl)%>
          <%= link_to "Edit", edit_todo_list_path(tl)%>

        </td>
      </tr>
      <% end %>
  </tbody>
</table>